###
# Вернуть список всех тегов
GET http://localhost:3001/api/tags HTTP/1.1

###
# Вернуть тег по text
GET http://localhost:3001/api/tags?text=prisma HTTP/1.1

###
# Вернуть тег по id
GET http://localhost:3001/api/tags/6b038ee3-5146-4bb5-99b2-a4b4296a2db0 HTTP/1.1

###
# Создать тег
POST http://localhost:3001/api/tags HTTP/1.1
Content-Type: application/json

{
  "text": "prisma"
}

###
# Удалить тег по id
DELETE http://localhost:3001/api/tags/6b038ee3-5146-4bb5-99b2-a4b4296a2db0 HTTP/1.1
